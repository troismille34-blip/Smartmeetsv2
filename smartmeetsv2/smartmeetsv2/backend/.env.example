# SmartMeets V2.0 Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://admin:secure_password@localhost:5432/smartmeets
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartmeets
DB_USER=admin
DB_PASSWORD=secure_password

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# OpenAI (Required for transcription)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email (SMTP) - Optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@smartmeets.app

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
FRONTEND_PROD_URL=https://smartmeets.app

# Outlook Calendar - Optional
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback

# Google Calendar - Optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Logging
LOG_LEVEL=debug
